#!/usr/bin/env dash

DIR=${HOME}/Pictures/screenshots
EDIT=false # set by -e
ZONE="f"   # default type

usage() {
	cat <<EOF
Usage: $(basename "$0") [-f|-w|-s] [-e]
  -f  full screen (default)
  -w  active window
  -s  select region
  -e  send capture to satty instead of clipboard
EOF
	exit 1
}

# ------------- option parsing -------------
while getopts ":fwshe" opt; do
	case $opt in
	f) ZONE="f" ;;
	w) ZONE="w" ;;
	s) ZONE="s" ;;
	e) EDIT=true ;;
	h) usage ;;
	\?)
		printf 'Unknown option: -%s\n' "$OPTARG" >&2
		usage
		;;
	esac
done
shift $((OPTIND - 1))

# ------------- helpers -------------
cleanup() {
	[ -n "$TMPDIR" ] && rm -rf "$TMPDIR"
}

round_corners() {
	TMPDIR=$(mktemp -d /tmp/screenshot_XXXXXX)
	trap cleanup EXIT INT TERM

	cat >"$TMPDIR/img.v"

	W=$(vipsheader -f width "$TMPDIR/img.v")
	H=$(vipsheader -f height "$TMPDIR/img.v")

	# Create SVG mask
	printf '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 %s %s"><rect rx="14" width="%s" height="%s" fill="white"/></svg>' "$W" "$H" "$W" "$H" >"$TMPDIR/mask.svg"

	# Extract alpha from SVG and join with image
	vips extract_band "$TMPDIR/mask.svg" "$TMPDIR/mask.v" 3
	vips bandjoin "$TMPDIR/img.v $TMPDIR/mask.v" "$IMG"
}

# ------------- main -------------
mkdir -p "$DIR"
IMG="$DIR/$(date +%Y-%m-%d_%Hh%Mm%Ss).png"

case "$ZONE" in
f) grim "$IMG" ;;
w)
	grim -g "$(hyprctl -j activewindow 2>/dev/null |
		jq -r '"\(.at[0] + 1),\(.at[1] + 1) \(.size[0] - 1)x\(.size[1] - 1)"')" - |
		round_corners
	;;
s) grim -g "$(slurp -d -w 1 -F "Iosevka Nerd Font")" "$IMG" ;;
esac

if [ "$EDIT" = true ]; then
	satty -f "$IMG"
else
	wl-copy <"$IMG" && notify-send -u low -i "/usr/share/icons/Papirus-Dark/128x128/mimetypes/x-content-image-picturecd.svg" "Screenshot" "Saved"
fi
